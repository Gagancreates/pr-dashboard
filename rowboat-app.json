{
  "schemaVersion": 1,
  "name": "pr-dashboard",
  "version": "0.1.1",
  "description": "Open PRs on rowboatlabs/rowboat",
  "capabilities": [
    "github"
  ],
  "dataContracts": [
    {
      "file": "data.json",
      "requiredKeys": [
        "updatedAt",
        "repo",
        "items"
      ],
      "nonEmptyArrayKeys": []
    }
  ],
  "agents": [
    "refresh.yaml"
  ]
}
